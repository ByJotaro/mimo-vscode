{
  "name": "mimo-vscode",
  "displayName": "MiMo Code",
  "publisher": "mimo",
  "description": "VS Code UI for MiMo Code CLI (OpenCode-compatible) with subagents, code diff, change lists, and undo/restore.",
  "icon": "media/marketplace-icon.png",
  "version": "0.6.10",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shiyong-Tan/OpenCodeGUI.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "MiMo Code",
    "open code",
    "ai coding",
    "code agent",
    "ai assistant",
    "coding assistant",
    "developer tools",
    "cli tools",
    "ai dev tools",
    "ai development",
    "llm",
    "openai"
  ],
  "activationEvents": [
    "onCommand:mimo.checkVersion",
    "onView:mimo.sidebar",
    "onStartupFinished"
  ],
  "main": "./out/ocgui/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mimo-activitybar",
          "title": "MiMo Code",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "mimo-activitybar": [
        {
          "type": "webview",
          "id": "mimo.sidebar",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "mimo.checkVersion",
        "title": "MiMo Code: Check Version"
      },
      {
        "command": "mimo.clearAttachmentsCache",
        "title": "MiMo Code: Clear Attachments Cache"
      },
      {
        "command": "mimo.sendSelectionToChat",
        "title": "MiMo Code: Send Selection to UI"
      },
      {
        "command": "mimo.sendOutputSelectionToChat",
        "title": "MiMo Code: Send Output Selection to UI"
      },
      {
        "command": "mimo.debugTuiControlSchema",
        "title": "MiMo Code: Debug TUI Control Schema"
      },
      {
        "command": "mimo.debugWebviewLivenessMissedAck",
        "title": "MiMo Code: Debug Webview Liveness Missed Ack"
      },
      {
        "command": "mimo.debugWebviewLivenessAckDropOn",
        "title": "MiMo Code: Debug Webview Liveness Ack Drop On"
      },
      {
        "command": "mimo.debugWebviewLivenessAckDropOff",
        "title": "MiMo Code: Debug Webview Liveness Ack Drop Off"
      },
      {
        "command": "mimo.clearStaleGitLocks",
        "title": "MiMo Code: Clear Stale Git Locks"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "mimo.sendSelectionToChat",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "mimo.sendOutputSelectionToChat",
          "when": "resourceScheme == 'output' && editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.0.8",
    "markdown-it": "^14.1.0"
  }
}



