{
  "name": "mimo-vscode",
  "displayName": "MiMo Code",
  "publisher": "mimo",
  "description": "MiMo Code VS Code sidebar — modular rewrite (v2). Fast DB-first history, CLI-faithful tools & theme.",
  "version": "1.0.0-beta.266",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByJotaro/mimo-vscode.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "MiMo Code",
    "AI coding",
    "code agent"
  ],
  "activationEvents": [
    "onView:mimo.sidebar",
    "onCommand:mimo.checkVersion",
    "onCommand:mimo.newSession",
    "onCommand:mimo.goHome",
    "onCommand:mimo.openHistory",
    "onCommand:mimo.insertSelection",
    "onCommand:mimo.abort",
    "onStartupFinished",
    "onCommand:mimo.openSidebar",
    "onCommand:mimo.exportSession",
    "onCommand:mimo.forkSession"
  ],
  "main": "./out/extension/activate.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mimo-activitybar",
          "title": "MiMo Code",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "mimo-activitybar": [
        {
          "type": "webview",
          "id": "mimo.sidebar",
          "name": "MiMo Code"
        }
      ]
    },
    "commands": [
      {
        "command": "mimo.checkVersion",
        "title": "MiMo Code: Check Version"
      },
      {
        "command": "mimo.openSidebar",
        "title": "MiMo Code: Open Chat",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "mimo.focusChat",
        "title": "MiMo Code: Focus Chat"
      },
      {
        "command": "mimo.newSession",
        "title": "MiMo Code: New Session"
      },
      {
        "command": "mimo.goHome",
        "title": "MiMo Code: Home"
      },
      {
        "command": "mimo.openHistory",
        "title": "MiMo Code: History"
      },
      {
        "command": "mimo.insertSelection",
        "title": "MiMo Code: Insert Editor Selection"
      },
      {
        "command": "mimo.abort",
        "title": "MiMo Code: Stop Turn"
      },
      {
        "command": "mimo.exportSession",
        "title": "MiMo Code: Export Session"
      },
      {
        "command": "mimo.forkSession",
        "title": "MiMo Code: Fork Session"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mimo.checkVersion",
          "when": "view == mimo.sidebar",
          "group": "navigation"
        },
        {
          "command": "mimo.newSession",
          "when": "view == mimo.sidebar",
          "group": "navigation"
        },
        {
          "command": "mimo.goHome",
          "when": "view == mimo.sidebar",
          "group": "navigation"
        },
        {
          "command": "mimo.exportSession",
          "when": "view == mimo.sidebar",
          "group": "navigation"
        },
        {
          "command": "mimo.openHistory",
          "when": "view == mimo.sidebar",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mimo.insertSelection",
          "group": "mimo@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mimo.openSidebar",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "mimo.newSession",
        "key": "ctrl+shift+alt+n",
        "mac": "cmd+shift+alt+n"
      },
      {
        "command": "mimo.insertSelection",
        "key": "ctrl+shift+alt+s",
        "mac": "cmd+shift+alt+s"
      },
      {
        "command": "mimo.abort",
        "key": "ctrl+shift+alt+.",
        "mac": "cmd+shift+alt+."
      }
    ],
    "configuration": {
      "title": "MiMo Code",
      "properties": {
        "mimo.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to mimo executable (empty = auto-detect / PATH / MIMO_BIN)."
        },
        "mimo.servePort": {
          "type": "number",
          "default": 0,
          "description": "Preferred loopback port for mimo serve (0 = hash from workspace)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node scripts/build-webview.mjs",
    "watch": "tsc -watch -p ./",
    "test": "node --test tests/unit/*.test.mjs tests/e2e/*.test.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:e2e": "node --test tests/e2e/*.test.mjs",
    "package": "npm run compile && npx --yes @vscode/vsce package --no-dependencies",
    "vscode:prepublish": "node -e \"process.exit(0)\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
